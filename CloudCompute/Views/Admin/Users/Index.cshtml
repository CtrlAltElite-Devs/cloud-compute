@using CloudCompute.Constants
@using CloudCompute.Models.Enums
@using CloudCompute.ViewModels.Admin
@model AdminUserListViewModel
@{
    Layout = "~/Views/Shared/Layouts/_AppLayout.cshtml";
    ViewData["Title"] = "Admin · Users";

    var statusMessage = TempData[AdminConstants.Status.TempDataMessageKey] as string;
    var statusType = TempData[AdminConstants.Status.TempDataTypeKey] as string;
    var alertClass = statusType == AdminConstants.Status.Danger ? "alert-danger" : "alert-success";
}

<section class="dashboard-page">
    <div class="dashboard-hero d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
        <div>
            <p class="text-uppercase text-muted small fw-semibold mb-1">Admin</p>
            <h1 class="dashboard-title mb-1">User management</h1>
            <p class="text-muted mb-0">@Model.TotalCount user@(Model.TotalCount == 1 ? "" : "s") match the current filter.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert @alertClass" role="alert">@statusMessage</div>
    }

    <section class="dashboard-panel mb-3">
        <form method="get" asp-action="Users" class="row g-2 align-items-end mb-0">
            <div class="col-md-4">
                <label class="form-label small">Search</label>
                <input type="search" name="Query" value="@Model.Filter.Query" class="form-control" placeholder="Name, username, or email" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Role</label>
                <select name="Role" class="form-select">
                    <option value="">Any</option>
                    @foreach (var role in Enum.GetValues<UserRole>())
                    {
                        <option value="@role" selected="@(Model.Filter.Role == role)">@role</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Status</label>
                <select name="IsActive" class="form-select">
                    <option value="">Any</option>
                    <option value="true" selected="@(Model.Filter.IsActive == true)">Active</option>
                    <option value="false" selected="@(Model.Filter.IsActive == false)">Suspended</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Verified</label>
                <select name="IsOwnerVerified" class="form-select">
                    <option value="">Any</option>
                    <option value="true" selected="@(Model.Filter.IsOwnerVerified == true)">Verified</option>
                    <option value="false" selected="@(Model.Filter.IsOwnerVerified == false)">Unverified</option>
                </select>
            </div>
            <div class="col-md-2 d-grid">
                <button type="submit" class="btn btn-primary">Filter</button>
            </div>
        </form>
    </section>

    @if (Model.Rows.Count == 0)
    {
        <div class="dashboard-empty-state">
            <i class="bi bi-people" aria-hidden="true"></i>
            <h3>No users match those filters</h3>
            <p>Adjust the search criteria above to broaden results.</p>
        </div>
    }
    else
    {
        <section class="dashboard-panel p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-striped mb-0 align-middle">
                    <thead>
                        <tr>
                            <th class="ps-4">User</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Verified</th>
                            <th class="text-end">Credits</th>
                            <th>Joined</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-semibold">@row.FullName</div>
                                    <div class="text-muted small">@row.UserName · @row.Email</div>
                                </td>
                                <td>@row.Role</td>
                                <td>
                                    @if (row.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger">Suspended</span>
                                    }
                                </td>
                                <td>
                                    @if (row.IsOwnerVerified)
                                    {
                                        <span class="badge bg-info-subtle text-info">Verified</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">&mdash;</span>
                                    }
                                </td>
                                <td class="text-end">@row.CreditBalance.ToString("N0")</td>
                                <td class="text-muted small">@row.CreatedAt.ToFriendlyDateTime()</td>
                                <td class="text-center">
                                    <a class="btn btn-link btn-sm text-secondary p-0" asp-action="UserDetail" asp-route-id="@row.Id" aria-label="View user" title="View">
                                        <i class="bi bi-eye-fill" aria-hidden="true"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-3" aria-label="User pagination">
                <ul class="pagination justify-content-center mb-0">
                    @for (var pageIndex = 1; pageIndex <= Model.TotalPages; pageIndex++)
                    {
                        <li class="page-item @(pageIndex == Model.Filter.Page ? "active" : "")">
                            <a class="page-link"
                               asp-action="Users"
                               asp-route-Query="@Model.Filter.Query"
                               asp-route-Role="@Model.Filter.Role"
                               asp-route-IsActive="@Model.Filter.IsActive"
                               asp-route-IsOwnerVerified="@Model.Filter.IsOwnerVerified"
                               asp-route-Page="@pageIndex">@pageIndex</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</section>
