@using CloudCompute.Constants
@using CloudCompute.Models.Enums
@using CloudCompute.ViewModels.Admin
@model AdminUserDetailViewModel
@{
    ViewData["Title"] = $"Admin · {Model.FullName}";

    var statusMessage = TempData[AdminConstants.Status.TempDataMessageKey] as string;
    var statusType = TempData[AdminConstants.Status.TempDataTypeKey] as string;
    var alertClass = statusType == AdminConstants.Status.Danger ? "alert-danger" : "alert-success";
}

<section class="py-5">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <p class="text-uppercase text-muted small fw-semibold mb-1">Admin · User</p>
                <h1 class="h3 mb-0">@Model.FullName</h1>
                <div class="text-muted small">@Model.UserName · @Model.Email</div>
            </div>
            <a class="btn btn-outline-secondary btn-sm" asp-action="Users">Back to users</a>
        </div>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="alert @alertClass" role="alert">@statusMessage</div>
        }

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="border rounded-3 p-4">
                    <h2 class="h6 text-uppercase text-muted small fw-semibold mb-3">Profile</h2>
                    <dl class="mb-0">
                        <dt class="small text-muted">Role</dt>
                        <dd>@Model.Role</dd>
                        <dt class="small text-muted">Status</dt>
                        <dd>
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger">Suspended</span>
                            }
                        </dd>
                        <dt class="small text-muted">Owner verified</dt>
                        <dd>@(Model.IsOwnerVerified ? "Yes" : "No")</dd>
                        <dt class="small text-muted">Credit balance</dt>
                        <dd>@Model.CreditBalance.ToString("N2")</dd>
                        <dt class="small text-muted">Joined</dt>
                        <dd class="mb-0">@Model.CreatedAt.ToString("u")</dd>
                    </dl>
                </div>

                @if (Model.Role != UserRole.Admin)
                {
                    <div class="border rounded-3 p-4 mt-3">
                        <h2 class="h6 text-uppercase text-muted small fw-semibold mb-3">Account actions</h2>
                        <div class="d-flex flex-wrap gap-2">
                            @if (Model.IsActive)
                            {
                                <form asp-action="SuspendUser" method="post">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Suspend</button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="ReactivateUser" method="post">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-outline-success btn-sm">Reactivate</button>
                                </form>
                            }

                            <form asp-action="ToggleOwnerVerified" method="post">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="isVerified" value="@((!Model.IsOwnerVerified).ToString().ToLowerInvariant())" />
                                <button type="submit" class="btn btn-outline-secondary btn-sm">
                                    @(Model.IsOwnerVerified ? "Revoke verification" : "Grant verification")
                                </button>
                            </form>

                            <a class="btn btn-outline-primary btn-sm" asp-action="GrantCredits" asp-route-userId="@Model.Id">Grant credits</a>
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-8">
                <div class="border rounded-3 p-4">
                    <h2 class="h6 text-uppercase text-muted small fw-semibold mb-3">Recent credit transactions</h2>
                    @if (Model.RecentCredits.Count == 0)
                    {
                        <p class="text-muted mb-0">No credit transactions yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm mb-0 align-middle">
                                <thead>
                                    <tr>
                                        <th>When</th>
                                        <th>Type</th>
                                        <th class="text-end">Amount</th>
                                        <th class="text-end">Balance</th>
                                        <th>Reason</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in Model.RecentCredits)
                                    {
                                        <tr>
                                            <td class="small text-muted">@t.CreatedAt.ToString("u")</td>
                                            <td>@t.Type</td>
                                            <td class="text-end @(t.Amount < 0 ? "text-danger" : "text-success")">@t.Amount.ToString("+0.##;-0.##;0")</td>
                                            <td class="text-end">@t.BalanceAfter.ToString("N2")</td>
                                            <td>@t.Reason</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <div class="border rounded-3 p-4 mt-3">
                    <h2 class="h6 text-uppercase text-muted small fw-semibold mb-3">Listings</h2>
                    @if (Model.Gpus.Count == 0)
                    {
                        <p class="text-muted mb-0">No GPU listings.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm mb-0 align-middle">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Model</th>
                                        <th>Status</th>
                                        <th class="text-end">Price/hr</th>
                                        <th>Created</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var g in Model.Gpus)
                                    {
                                        <tr>
                                            <td>@g.Name</td>
                                            <td>@g.Model</td>
                                            <td>@g.Status</td>
                                            <td class="text-end">@g.PricePerHour.ToString("N2")</td>
                                            <td class="small text-muted">@g.CreatedAt.ToString("u")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
