@using CloudCompute.Constants
@using CloudCompute.Models.Enums
@using CloudCompute.ViewModels.Admin
@model AdminUserDetailViewModel
@{
    Layout = "~/Views/Shared/Layouts/_AppLayout.cshtml";
    ViewData["Title"] = $"Admin · {Model.FullName}";

    var statusMessage = TempData[AdminConstants.Status.TempDataMessageKey] as string;
    var statusType = TempData[AdminConstants.Status.TempDataTypeKey] as string;
    var alertClass = statusType == AdminConstants.Status.Danger ? "alert-danger" : "alert-success";

    string GpuStatusVariant(GpuStatus s) => s switch
    {
        GpuStatus.Available => "success",
        GpuStatus.Rented => "warning",
        GpuStatus.Maintenance => "warning",
        GpuStatus.Pending => "info",
        GpuStatus.Rejected => "danger",
        GpuStatus.Unavailable => "secondary",
        _ => "secondary"
    };

    (string Variant, string Label) CreditTypeBadge(CreditTransactionType type) => type switch
    {
        CreditTransactionType.Initial => ("secondary", "Initial"),
        CreditTransactionType.AdminGrant => ("primary", "Admin grant"),
        CreditTransactionType.RentalCharge => ("danger", "Rental charge"),
        CreditTransactionType.RentalEarning => ("success", "Rental earning"),
        CreditTransactionType.Refund => ("info", "Refund"),
        CreditTransactionType.Revoke => ("warning", "Revoke"),
        _ => ("secondary", type.ToString())
    };
}

<section class="dashboard-page">
    <div class="dashboard-hero d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
        <div>
            <p class="text-uppercase text-muted small fw-semibold mb-1">Admin · User</p>
            <h1 class="dashboard-title mb-1">@Model.FullName</h1>
            <p class="text-muted mb-0">@Model.UserName · @Model.Email</p>
        </div>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Users">Back to users</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert @alertClass" role="alert">@statusMessage</div>
    }

    <div class="row g-3">
        <div class="col-lg-4">
            <section class="dashboard-panel" aria-labelledby="userProfileTitle">
                <div class="dashboard-panel-header">
                    <h2 class="dashboard-panel-title" id="userProfileTitle">
                        <i class="bi bi-person" aria-hidden="true"></i>
                        Profile
                    </h2>
                </div>
                <dl class="row g-3 mb-0">
                    <div class="col-6">
                        <dt class="small text-muted fw-normal">Role</dt>
                        <dd class="mb-0">@Model.Role</dd>
                    </div>
                    <div class="col-6">
                        <dt class="small text-muted fw-normal">Status</dt>
                        <dd class="mb-0">
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger">Suspended</span>
                            }
                        </dd>
                    </div>
                    <div class="col-6">
                        <dt class="small text-muted fw-normal">Owner verified</dt>
                        <dd class="mb-0">@(Model.IsOwnerVerified ? "Yes" : "No")</dd>
                    </div>
                    <div class="col-6">
                        <dt class="small text-muted fw-normal">Credit balance</dt>
                        <dd class="mb-0">@Model.CreditBalance.ToString("N2")</dd>
                    </div>
                    <div class="col-12">
                        <dt class="small text-muted fw-normal">Joined</dt>
                        <dd class="mb-0">@Model.CreatedAt.ToFriendlyDateTime()</dd>
                    </div>
                </dl>
            </section>

            @if (Model.Role != UserRole.Admin)
            {
                <section class="dashboard-panel mt-3" aria-labelledby="userActionsTitle">
                    <div class="dashboard-panel-header">
                        <h2 class="dashboard-panel-title" id="userActionsTitle">
                            <i class="bi bi-sliders" aria-hidden="true"></i>
                            Account actions
                        </h2>
                    </div>
                    <div class="d-flex flex-wrap gap-3">
                        @if (Model.IsActive)
                        {
                            <form asp-action="SuspendUser" method="post">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-danger btn-sm">Suspend</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="ReactivateUser" method="post">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-success btn-sm">Reactivate</button>
                            </form>
                        }

                        <form asp-action="ToggleOwnerVerified" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="isVerified" value="@((!Model.IsOwnerVerified).ToString().ToLowerInvariant())" />
                            <button type="submit" class="btn btn-outline-secondary btn-sm">
                                @(Model.IsOwnerVerified ? "Revoke verification" : "Grant verification")
                            </button>
                        </form>

                        <a class="btn btn-primary btn-sm" asp-action="GrantCredits" asp-route-userId="@Model.Id">Grant credits</a>
                    </div>
                </section>
            }
        </div>

        <div class="col-lg-8">
            <section class="dashboard-panel" aria-labelledby="userCreditsTitle">
                <div class="dashboard-panel-header">
                    <h2 class="dashboard-panel-title" id="userCreditsTitle">
                        <i class="bi bi-coin" aria-hidden="true"></i>
                        Recent credit transactions
                    </h2>
                </div>
                @if (Model.RecentCredits.Count == 0)
                {
                    <p class="text-muted mb-0">No credit transactions yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-striped mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>When</th>
                                    <th>Type</th>
                                    <th class="text-end">Amount</th>
                                    <th class="text-end">Balance</th>
                                    <th>Reason</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in Model.RecentCredits)
                                {
                                    <tr>
                                        <td class="small text-muted">@t.CreatedAt.ToFriendlyDateTime()</td>
                                        <td>
                                            @{ var typeBadge = CreditTypeBadge(t.Type); }
                                            <span class="badge bg-@(typeBadge.Variant)-subtle text-@(typeBadge.Variant)">@typeBadge.Label</span>
                                        </td>
                                        <td class="text-end @(t.Amount < 0 ? "text-danger" : "text-success")">@t.Amount.ToString("+0.##;-0.##;0")</td>
                                        <td class="text-end">@t.BalanceAfter.ToString("N2")</td>
                                        <td>@t.Reason</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>

            <section class="dashboard-panel mt-3" aria-labelledby="userListingsTitle">
                <div class="dashboard-panel-header">
                    <h2 class="dashboard-panel-title" id="userListingsTitle">
                        <i class="bi bi-card-list" aria-hidden="true"></i>
                        Listings
                    </h2>
                </div>
                @if (Model.Gpus.Count == 0)
                {
                    <p class="text-muted mb-0">No GPU listings.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-striped mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Model</th>
                                    <th>Status</th>
                                    <th class="text-end">Price/hr</th>
                                    <th>Created</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var g in Model.Gpus)
                                {
                                    <tr>
                                        <td>@g.Name</td>
                                        <td>@g.Model</td>
                                        <td>
                                            @{ var variant = GpuStatusVariant(g.Status); }
                                            <span class="badge bg-@(variant)-subtle text-@(variant)">@g.Status</span>
                                        </td>
                                        <td class="text-end">@g.PricePerHour.ToString("N2") credits</td>
                                        <td class="small text-muted">@g.CreatedAt.ToFriendlyDateTime()</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        </div>
    </div>
</section>
