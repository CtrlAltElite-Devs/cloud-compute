@model IReadOnlyList<VerificationRequestRowViewModel>
@{
    Layout = "~/Views/Shared/Layouts/_AppLayout.cshtml";
    ViewData["Title"] = "Verification queue";

    var statusMessage = TempData[CloudCompute.Constants.VerificationConstants.Status.TempDataMessageKey] as string;
    var statusType = TempData[CloudCompute.Constants.VerificationConstants.Status.TempDataTypeKey] as string;
    var alertClass = statusType == "danger" ? "alert-danger" : "alert-success";
}

<section class="dashboard-page">
    <div class="dashboard-hero d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
        <div>
            <p class="text-uppercase text-muted small fw-semibold mb-1">Admin</p>
            <h1 class="dashboard-title mb-1">Owner verification queue</h1>
            <p class="text-muted mb-0">Review submitted IDs and approve or reject pending owner verifications.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert @alertClass" role="alert">@statusMessage</div>
    }

    @if (Model.Count == 0)
    {
        <div class="dashboard-empty-state">
            <i class="bi bi-patch-check" aria-hidden="true"></i>
            <h3>No pending verifications</h3>
            <p>New verification requests will appear here once members submit them.</p>
        </div>
    }
    else
    {
        <section class="dashboard-panel p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead>
                        <tr>
                            <th scope="col" class="ps-4">User</th>
                            <th scope="col">Justification</th>
                            <th scope="col">ID</th>
                            <th scope="col">Submitted</th>
                            <th scope="col" class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-semibold">@row.UserFullName</div>
                                    <div class="text-muted small">@row.UserEmail</div>
                                </td>
                                <td style="max-width: 32rem;">
                                    <div class="text-truncate" style="white-space: pre-line;" title="@row.Justification">@row.Justification</div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(row.IdentityImagePath))
                                    {
                                        <a href="@row.IdentityImagePath" target="_blank" rel="noopener">
                                            <img src="@row.IdentityImagePath" alt="ID for @row.UserFullName" class="img-thumbnail" style="max-width: 96px; max-height: 64px;" loading="lazy" />
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">&mdash;</span>
                                    }
                                </td>
                                <td class="text-muted small">@row.SubmittedAt.ToFriendlyDateTime()</td>
                                <td class="text-end pe-4">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#approve-@row.Id">Approve</button>
                                        <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#reject-@row.Id">Reject</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        @foreach (var row in Model)
        {
            <div class="modal fade" id="approve-@row.Id" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <form asp-action="ApproveVerification" method="post" class="modal-content">
                        <div class="modal-header">
                            <h2 class="h5 modal-title">Approve verification</h2>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <p class="mb-3">Mark <strong>@row.UserFullName</strong> as a verified owner.</p>
                            @if (!string.IsNullOrWhiteSpace(row.IdentityImagePath))
                            {
                                <p class="text-uppercase text-muted small fw-semibold mb-1">Submitted ID</p>
                                <img src="@row.IdentityImagePath" alt="ID for @row.UserFullName" class="img-fluid img-thumbnail mb-3" loading="lazy" />
                            }
                            <input type="hidden" name="id" value="@row.Id" />
                            <div class="mb-0">
                                <label class="form-label" for="approve-notes-@row.Id">Reviewer notes (optional)</label>
                                <textarea class="form-control" id="approve-notes-@row.Id" name="notes" rows="3"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-link" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-success">Approve</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="modal fade" id="reject-@row.Id" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <form asp-action="RejectVerification" method="post" class="modal-content">
                        <div class="modal-header">
                            <h2 class="h5 modal-title">Reject verification</h2>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <p class="mb-3">Reject the verification request from <strong>@row.UserFullName</strong>.</p>
                            @if (!string.IsNullOrWhiteSpace(row.IdentityImagePath))
                            {
                                <p class="text-uppercase text-muted small fw-semibold mb-1">Submitted ID</p>
                                <img src="@row.IdentityImagePath" alt="ID for @row.UserFullName" class="img-fluid img-thumbnail mb-3" loading="lazy" />
                            }
                            <input type="hidden" name="id" value="@row.Id" />
                            <div class="mb-0">
                                <label class="form-label" for="reject-notes-@row.Id">Reviewer notes (optional)</label>
                                <textarea class="form-control" id="reject-notes-@row.Id" name="notes" rows="3" placeholder="Why is this being rejected?"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-link" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-danger">Reject</button>
                        </div>
                    </form>
                </div>
            </div>
        }
    }
</section>
