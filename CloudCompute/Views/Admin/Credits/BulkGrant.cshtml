@using CloudCompute.ViewModels.Admin
@model AdminBulkGrantViewModel
@{
    ViewData["Title"] = "Admin · Bulk grant";
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div>
                        <p class="text-uppercase text-muted small fw-semibold mb-1">Admin · Credits</p>
                        <h1 class="h3 mb-0">Bulk credit grant</h1>
                    </div>
                    <a class="btn btn-outline-secondary btn-sm" asp-action="Credits">Back to ledger</a>
                </div>

                <partial name="~/Views/Shared/Partials/_ModelStateAlert.cshtml" />

                <form asp-action="BulkGrantCredits" method="post" class="border rounded-3 p-4">
                    <p class="text-muted">Grants the same amount to every member account. Wrapped in a single database transaction.</p>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Amount">Amount per user</label>
                        <input class="form-control" asp-for="Amount" type="number" step="0.01" min="1" max="100000" />
                        <span asp-validation-for="Amount" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Reason">Reason</label>
                        <textarea class="form-control" asp-for="Reason" rows="3" placeholder="e.g. Quarterly bonus"></textarea>
                        <span asp-validation-for="Reason" class="text-danger small"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="ActiveMembersOnly" />
                        <label class="form-check-label" asp-for="ActiveMembersOnly">Only grant to active members (skip suspended accounts)</label>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <a class="btn btn-link" asp-action="Credits">Cancel</a>
                        <button type="submit" class="btn btn-primary">Grant to all members</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="~/Views/Shared/Partials/_ValidationScriptsPartial.cshtml" />
}
