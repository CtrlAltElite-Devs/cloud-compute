@using CloudCompute.ViewModels.Admin
@model AdminRevokeCreditViewModel
@{
    ViewData["Title"] = "Admin · Revoke credits";
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div>
                        <p class="text-uppercase text-muted small fw-semibold mb-1">Admin · Credits</p>
                        <h1 class="h3 mb-0">Revoke credits</h1>
                    </div>
                    <a class="btn btn-outline-secondary btn-sm" asp-action="Credits">Back to ledger</a>
                </div>

                <partial name="~/Views/Shared/Partials/_ModelStateAlert.cshtml" />

                <form asp-action="RevokeCredits" method="post" class="border rounded-3 p-4">
                    <div class="mb-3">
                        <label class="form-label" asp-for="UserId">User ID</label>
                        <input class="form-control" asp-for="UserId" placeholder="GUID" />
                        @if (!string.IsNullOrWhiteSpace(Model.UserDisplay))
                        {
                            <div class="form-text">Revoking from: <strong>@Model.UserDisplay</strong></div>
                        }
                        <span asp-validation-for="UserId" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Amount">Amount to deduct</label>
                        <input class="form-control" asp-for="Amount" type="number" step="0.01" min="1" max="100000" />
                        <span asp-validation-for="Amount" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Reason">Reason</label>
                        <textarea class="form-control" asp-for="Reason" rows="3" placeholder="Why are credits being revoked?"></textarea>
                        <span asp-validation-for="Reason" class="text-danger small"></span>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <a class="btn btn-link" asp-action="Credits">Cancel</a>
                        <button type="submit" class="btn btn-danger">Revoke credits</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="~/Views/Shared/Partials/_ValidationScriptsPartial.cshtml" />
}
