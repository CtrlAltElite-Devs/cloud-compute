@using CloudCompute.Constants
@using CloudCompute.Models.Enums
@using CloudCompute.ViewModels.Admin
@model AdminListingListViewModel
@{
    Layout = "~/Views/Shared/Layouts/_AppLayout.cshtml";
    ViewData["Title"] = "Admin · Listings";

    var statusMessage = TempData[AdminConstants.Status.TempDataMessageKey] as string;
    var statusType = TempData[AdminConstants.Status.TempDataTypeKey] as string;
    var alertClass = statusType == AdminConstants.Status.Danger ? "alert-danger" : "alert-success";

    string GpuStatusVariant(GpuStatus s) => s switch
    {
        GpuStatus.Available => "success",
        GpuStatus.Rented => "warning",
        GpuStatus.Maintenance => "warning",
        GpuStatus.Pending => "info",
        GpuStatus.Rejected => "danger",
        GpuStatus.Unavailable => "secondary",
        _ => "secondary"
    };
}

<section class="dashboard-page">
    <div class="dashboard-hero d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
        <div>
            <p class="text-uppercase text-muted small fw-semibold mb-1">Admin</p>
            <h1 class="dashboard-title mb-1">Listing moderation</h1>
            <p class="text-muted mb-0">Review and act on submitted GPU listings.</p>
        </div>
        <div class="btn-group flex-wrap" role="group" aria-label="Listing status filter">
            @foreach (var status in Enum.GetValues<GpuStatus>())
            {
                var count = Model.CountsByStatus.TryGetValue(status, out var n) ? n : 0;
                var isActive = !Model.Filter.All && Model.Filter.Status == status;
                <a class="btn btn-sm @(isActive ? "btn-primary" : "bg-primary-subtle text-white border-primary-subtle")"
                   asp-action="Listings"
                   asp-route-Status="@status">
                    @status <span class="badge text-bg-primary ms-1">@count</span>
                </a>
            }
            <a class="btn btn-sm @(Model.Filter.All ? "btn-primary" : "bg-primary-subtle text-white border-primary-subtle")"
               asp-action="Listings"
               asp-route-all="true">All</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert @alertClass" role="alert">@statusMessage</div>
    }

    <section class="dashboard-panel mb-3">
        <form method="get" asp-action="Listings" class="row g-2 align-items-end mb-0">
            @if (Model.Filter.All)
            {
                <input type="hidden" name="All" value="true" />
            }
            else
            {
                <input type="hidden" name="Status" value="@Model.Filter.Status" />
            }
            <div class="col-md-6">
                <label class="form-label small">Owner search</label>
                <input type="search" name="OwnerQuery" value="@Model.Filter.OwnerQuery" class="form-control" placeholder="Owner name, username, or email" />
            </div>
            <div class="col-md-2 d-grid">
                <button type="submit" class="btn btn-primary">Filter</button>
            </div>
        </form>
    </section>

    @if (Model.Rows.Count == 0)
    {
        <div class="dashboard-empty-state">
            <i class="bi bi-card-list" aria-hidden="true"></i>
            <h3>No listings match those filters</h3>
            <p>Adjust the status or owner search above to broaden results.</p>
        </div>
    }
    else
    {
        <section class="dashboard-panel p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-striped mb-0 align-middle">
                    <thead>
                        <tr>
                            <th class="ps-4">Photo</th>
                            <th>Listing</th>
                            <th>Owner</th>
                            <th>Status</th>
                            <th class="text-end">Price/hr</th>
                            <th>Submitted</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td class="ps-4">
                                    @if (!string.IsNullOrWhiteSpace(row.ImagePath))
                                    {
                                        <img src="@row.ImagePath" alt="" class="img-thumbnail" style="max-width: 96px; max-height: 64px;" loading="lazy" />
                                    }
                                    else
                                    {
                                        <span class="text-muted small">&mdash;</span>
                                    }
                                </td>
                                <td>
                                    <div class="fw-semibold">@row.Name</div>
                                    <div class="text-muted small">@row.Model</div>
                                </td>
                                <td>@row.OwnerDisplay</td>
                                <td>
                                    @{ var variant = GpuStatusVariant(row.Status); }
                                    <span class="badge bg-@(variant)-subtle text-@(variant)">@row.Status</span>
                                </td>
                                <td class="text-end">@row.PricePerHour.ToString("N2")</td>
                                <td class="small text-muted">@row.CreatedAt.ToFriendlyDateTime()</td>
                                <td class="text-center">
                                    <a class="btn btn-link btn-sm text-secondary p-0" asp-action="ListingDetail" asp-route-id="@row.Id" aria-label="Review listing" title="Review">
                                        <i class="bi bi-eye-fill" aria-hidden="true"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-3" aria-label="Listings pagination">
                <ul class="pagination justify-content-center mb-0">
                    @for (var pageIndex = 1; pageIndex <= Model.TotalPages; pageIndex++)
                    {
                        <li class="page-item @(pageIndex == Model.Filter.Page ? "active" : "")">
                            <a class="page-link"
                               asp-action="Listings"
                               asp-route-Status="@(Model.Filter.All ? null : Model.Filter.Status?.ToString())"
                               asp-route-all="@(Model.Filter.All ? "true" : null)"
                               asp-route-OwnerQuery="@Model.Filter.OwnerQuery"
                               asp-route-Page="@pageIndex">@pageIndex</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</section>
