@model LoginViewModel

@{
    Layout = "~/Views/Shared/Layouts/_AuthLayout.cshtml";
    ViewData["Title"] = "Admin Login";
    ViewData["BodyClass"] = "auth-page";
}

<section class="auth-shell row g-0 min-vh-100">
    <div class="auth-visual-panel col-lg-6 d-none d-lg-flex align-items-center position-relative overflow-hidden p-5">
        <div class="auth-visual-content position-relative z-1">
            <a asp-action="Index" asp-controller="Landing" aria-label="Go to CloudCompute landing page">
                <img class="auth-logo-mark" src="~/images/logo.png" asp-append-version="true" alt="CloudCompute" />
            </a>
            <h1 class="auth-hero-title display-3 fw-bold lh-1 mb-4">
                Manage platform access, compute listings, and credit operations.
            </h1>
            <p class="auth-hero-copy lead mb-0">
                Administrative access is limited to approved CloudCompute operators.
            </p>
        </div>
    </div>

    <div class="auth-form-panel col-lg-6 d-flex align-items-center justify-content-center min-vh-100 p-4 p-sm-5">
        <form class="auth-form w-100" asp-action="Login" asp-controller="Admin" method="post">
            <div class="text-center mb-5">
                <h2 class="fs-1 fw-bold mb-3">Admin Login</h2>
                <p class="auth-muted mb-0">Please enter your admin email or username and password.</p>
            </div>

            <partial name="~/Views/Shared/Partials/_ModelStateAlert.cshtml" />

            <div class="mb-3">
                <label class="form-label auth-label" asp-for="LoginIdentifier"></label>
                <input class="form-control auth-input" asp-for="LoginIdentifier" autocomplete="username" placeholder="Enter your email or username" />
                <span class="text-danger small" asp-validation-for="LoginIdentifier"></span>
            </div>

            <div class="mb-3">
                <label class="form-label auth-label" asp-for="Password"></label>
                <input class="form-control auth-input" asp-for="Password" autocomplete="current-password" placeholder="Enter your password" />
                <span class="text-danger small" asp-validation-for="Password"></span>
            </div>

            <div class="form-check mb-5">
                <input class="form-check-input" asp-for="RememberMe" />
                <label class="form-check-label auth-muted" asp-for="RememberMe">Remember me</label>
            </div>

            <button class="btn btn-primary w-100 fw-bold py-3 mb-5" type="submit">Login</button>

            <p class="auth-muted text-center mb-0">
                <a class="auth-link fw-bold text-decoration-none" asp-action="Login" asp-controller="Auth">Member login</a>
            </p>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="~/Views/Shared/Partials/_ValidationScriptsPartial.cshtml" />
}
