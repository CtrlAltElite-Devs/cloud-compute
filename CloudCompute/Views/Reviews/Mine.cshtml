@model MyReviewsViewModel
@{
    Layout = "~/Views/Shared/Layouts/_AppLayout.cshtml";
    ViewData["Title"] = "My Reviews";
}

<section class="mb-4">
    <p class="text-uppercase text-muted small fw-semibold mb-1">Platform</p>
    <h1 class="h3 mb-1">My Reviews</h1>
    <p class="text-muted mb-0">Reviews you have submitted for completed GPU rentals.</p>
</section>

@if (Model.Items.Count == 0)
{
    <div class="profile-card text-center py-5">
        <i class="bi bi-star fs-1 text-muted" aria-hidden="true"></i>
        <h2 class="h5 mt-3 mb-2">No reviews yet</h2>
        <p class="text-muted mb-3">Completed rentals you review will appear here.</p>
        <a class="btn btn-info" asp-controller="Rentals" asp-action="History">View rental history</a>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var item in Model.Items)
        {
            <article class="profile-card">
                <div class="d-flex flex-column flex-lg-row gap-3">
                    <div class="flex-shrink-0">
                        @if (!string.IsNullOrWhiteSpace(item.ImagePath))
                        {
                            <img src="@item.ImagePath" alt="@item.GpuModel" class="rounded-3" style="width:132px;height:96px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="rounded-3 d-flex align-items-center justify-content-center bg-body-secondary text-muted" style="width:132px;height:96px;">
                                <i class="bi bi-cpu fs-3" aria-hidden="true"></i>
                            </div>
                        }
                    </div>

                    <div class="flex-grow-1 min-width-0">
                        <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-2">
                            <div class="min-width-0">
                                <h2 class="h5 mb-1">@item.GpuModel</h2>
                                <div class="text-muted small">@item.GpuName by @item.OwnerDisplayName</div>
                                <div class="text-muted small">@item.ReferenceNumber</div>
                            </div>
                            <div class="text-warning flex-shrink-0" aria-label="@item.Rating out of 5 stars">
                                @for (var i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= item.Rating ? "bi-star-fill" : "bi-star")" aria-hidden="true"></i>
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(item.Comment))
                        {
                            <p class="mb-3 text-muted">@item.Comment</p>
                        }
                        else
                        {
                            <p class="mb-3 text-muted fst-italic">No comment provided.</p>
                        }

                        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                            <div class="small text-muted">Reviewed @item.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</div>
                            <div class="d-flex flex-wrap gap-2">
                                <a class="btn btn-sm btn-outline-secondary" asp-controller="Rentals" asp-action="Receipt" asp-route-rentalId="@item.RentalId">
                                    <i class="bi bi-receipt me-1" aria-hidden="true"></i> Receipt
                                </a>
                                <a class="btn btn-sm btn-outline-info" asp-controller="Gpus" asp-action="Detail" asp-route-id="@item.GpuId">
                                    <i class="bi bi-cpu me-1" aria-hidden="true"></i> GPU
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </article>
        }
    </div>
}
