@using CloudCompute.Constants
@model NotificationListViewModel
@{
    Layout = "~/Views/Shared/Layouts/_AppLayout.cshtml";
    ViewData["Title"] = "Notifications";

    var statusMessage = TempData[NotificationConstants.Status.TempDataMessageKey] as string;
    var statusType = TempData[NotificationConstants.Status.TempDataTypeKey] as string;
    var alertClass = statusType == NotificationConstants.Status.Danger ? "alert-danger" : "alert-success";
    var hasUnread = Model.UnreadCount > 0;
}

<section class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Notifications</h1>
        <p class="text-muted mb-0">Updates about your listings, credits, and rentals.</p>
    </div>
    <form asp-action="MarkAllRead" method="post" class="m-0">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-secondary @(hasUnread ? "" : "opacity-50")"
                disabled="@(!hasUnread)" title="Mark all as read">
            <i class="bi bi-check2-all me-1" aria-hidden="true"></i> Mark all as read
        </button>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @alertClass" role="alert">@statusMessage</div>
}

@if (Model.Items.Count == 0)
{
    <div class="profile-card text-center py-5">
        <i class="bi bi-bell-slash fs-1 text-muted" aria-hidden="true"></i>
        <h2 class="h5 mt-3 mb-2">No notifications yet</h2>
        <p class="text-muted mb-0">You'll see updates about your listings and credits here.</p>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var item in Model.Items)
        {
            <div class="@item.RowCssClass">
                <div class="d-flex flex-wrap align-items-center gap-3">
                    <div class="flex-shrink-0">
                        <div class="rounded-3 d-flex align-items-center justify-content-center bg-body-secondary"
                             style="width:56px;height:56px;">
                            <i class="bi @item.IconCssClass fs-3" aria-hidden="true"></i>
                        </div>
                    </div>

                    <div class="flex-grow-1 min-width-0">
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                            <span class="badge @item.BadgeCssClass">@item.BadgeLabel</span>
                            @if (!item.IsRead)
                            {
                                <span class="badge bg-info-subtle text-info-emphasis">NEW</span>
                            }
                        </div>
                        <div class="@(item.IsRead ? "" : "fw-semibold")">@item.Message</div>
                        <div class="text-muted small mt-1">@item.RelativeTime</div>
                    </div>

                    <div class="d-flex align-items-center gap-2 flex-shrink-0">
                        @if (item.HasLink)
                        {
                            <form asp-action="Open" asp-route-id="@item.Id" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-info"
                                        aria-label="Open notification" title="Open">
                                    <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
                                </button>
                            </form>
                        }

                        @if (!item.IsRead)
                        {
                            <form asp-action="MarkRead" asp-route-id="@item.Id" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-secondary"
                                        aria-label="Mark as read" title="Mark as read">
                                    <i class="bi bi-check2" aria-hidden="true"></i>
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="btn btn-sm btn-outline-secondary disabled" aria-disabled="true"
                                  title="Already read">
                                <i class="bi bi-check2" aria-hidden="true"></i>
                            </span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
