@using CloudCompute.Constants
@model ActiveRentalsViewModel
@{
    Layout = "~/Views/Shared/Layouts/_AppLayout.cshtml";
    ViewData["Title"] = "Active Rentals";

    var statusMessage = TempData[GpuConstants.Status.TempDataMessageKey] as string;
    var statusType = TempData[GpuConstants.Status.TempDataTypeKey] as string;
    var alertClass = statusType == "danger" ? "alert-danger" : "alert-success";
    var now = DateTime.UtcNow;
}

<section class="mb-4">
    <p class="text-uppercase text-muted small fw-semibold mb-1">Platform</p>
    <h1 class="h3 mb-1">Active Rentals</h1>
    <p class="text-muted mb-0">Track your in-progress GPU rentals.</p>
</section>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @alertClass" role="alert">@statusMessage</div>
}

@if (Model.Items.Count == 0)
{
    <div class="profile-card text-center py-5">
        <i class="bi bi-lightning-charge fs-1 text-muted" aria-hidden="true"></i>
        <h2 class="h5 mt-3 mb-2">No active rentals</h2>
        <p class="text-muted mb-3">Rent an available GPU to start a compute session.</p>
        <a class="btn btn-info" asp-controller="Gpus" asp-action="Index">Browse GPUs</a>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var item in Model.Items)
        {
            var totalSeconds = Math.Max((item.EndTime - item.StartTime).TotalSeconds, 1);
            var elapsedSeconds = Math.Clamp((now - item.StartTime).TotalSeconds, 0, totalSeconds);
            var usedPercent = (int)Math.Round(elapsedSeconds / totalSeconds * 100);
            var timeLeft = item.EndTime > now ? item.EndTime - now : TimeSpan.Zero;
            var timeLeftText = $"{(int)timeLeft.TotalHours:00}:{timeLeft.Minutes:00}:{timeLeft.Seconds:00}";

            <article class="profile-card active-rental-card" data-start="@DateTime.SpecifyKind(item.StartTime, DateTimeKind.Utc).ToString("O")" data-end="@DateTime.SpecifyKind(item.EndTime, DateTimeKind.Utc).ToString("O")">
                <div class="d-flex flex-column flex-xl-row align-items-xl-center gap-4">
                    <div class="d-flex align-items-center gap-3" style="min-width: 280px;">
                        @if (!string.IsNullOrWhiteSpace(item.ImagePath))
                        {
                            <img src="@item.ImagePath" alt="@item.GpuModel" class="rounded-3 flex-shrink-0" style="width:132px;height:92px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="rounded-3 d-flex align-items-center justify-content-center bg-body-secondary text-muted flex-shrink-0" style="width:132px;height:92px;">
                                <i class="bi bi-cpu fs-3" aria-hidden="true"></i>
                            </div>
                        }

                        <div class="min-width-0">
                            <h2 class="h5 mb-1">@item.GpuModel</h2>
                            <div class="text-muted">by @item.OwnerDisplayName</div>
                        </div>
                    </div>

                    <div class="flex-grow-1 min-width-0">
                        <div class="text-muted small mb-2">Time Left</div>
                        <div class="h3 mb-2 text-info" data-rental-time-left>@timeLeftText</div>
                        <div class="progress mb-2" role="progressbar" aria-label="Rental usage" aria-valuenow="@usedPercent" aria-valuemin="0" aria-valuemax="100" style="height: 6px;" data-rental-progress>
                            <div class="progress-bar bg-info" style="width: @usedPercent%" data-rental-progress-bar></div>
                        </div>
                        <div class="d-flex flex-wrap justify-content-between gap-2 text-muted small">
                            <span>@item.StartTime.ToLocalTime().ToString("MMM d, yyyy h:mm tt") -> @item.EndTime.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
                            <span data-rental-used-percent>@usedPercent% used</span>
                        </div>
                    </div>

                    <div class="d-flex flex-xl-column gap-2 flex-shrink-0">
                        <button
                            type="button"
                            class="btn btn-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#terminateRentalModal"
                            data-rental-reference="@item.ReferenceNumber"
                            data-rental-title="@item.GpuModel"
                            data-rental-action="@Url.Action("Terminate", "Rentals", new { rentalId = item.Id })"
                            aria-label="Terminate rental"
                            title="Terminate rental">
                            <i class="bi bi-stop-circle" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
            </article>
        }
    </div>

    <div class="modal fade" id="terminateRentalModal" tabindex="-1" aria-labelledby="terminateRentalModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="terminateRentalModalLabel">Terminate rental?</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">This will end <strong data-terminate-rental-title></strong> immediately and make the GPU available again.</p>
                    <p class="text-muted small mb-0">Rental <span data-terminate-rental-reference></span> will be marked as terminated. Credits will not be refunded.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form method="post" data-terminate-rental-form>
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">Terminate rental</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        (() => {
            const formatDuration = (milliseconds) => {
                const totalSeconds = Math.max(0, Math.floor(milliseconds / 1000));
                const hours = Math.floor(totalSeconds / 3600);
                const minutes = Math.floor((totalSeconds % 3600) / 60);
                const seconds = totalSeconds % 60;

                return [hours, minutes, seconds]
                    .map((value) => value.toString().padStart(2, "0"))
                    .join(":");
            };

            let reloadScheduled = false;

            const updateRentalTimers = () => {
                const now = Date.now();
                let hasExpiredRental = false;

                document.querySelectorAll(".active-rental-card").forEach((card) => {
                    const start = Date.parse(card.dataset.start);
                    const end = Date.parse(card.dataset.end);
                    const total = Math.max(end - start, 1);
                    const elapsed = Math.min(Math.max(now - start, 0), total);
                    const usedPercent = Math.min(Math.round((elapsed / total) * 100), 100);
                    const timeLeft = Math.max(end - now, 0);

                    const timeLeftEl = card.querySelector("[data-rental-time-left]");
                    const progressEl = card.querySelector("[data-rental-progress]");
                    const progressBarEl = card.querySelector("[data-rental-progress-bar]");
                    const usedPercentEl = card.querySelector("[data-rental-used-percent]");

                    if (timeLeftEl) {
                        timeLeftEl.textContent = formatDuration(timeLeft);
                    }

                    if (progressEl) {
                        progressEl.setAttribute("aria-valuenow", usedPercent.toString());
                    }

                    if (progressBarEl) {
                        progressBarEl.style.width = `${usedPercent}%`;
                    }

                    if (usedPercentEl) {
                        usedPercentEl.textContent = `${usedPercent}% used`;
                    }

                    if (now >= end) {
                        hasExpiredRental = true;
                    }
                });

                if (hasExpiredRental && !reloadScheduled) {
                    reloadScheduled = true;
                    window.setTimeout(() => window.location.reload(), 1500);
                }
            };

            updateRentalTimers();
            window.setInterval(updateRentalTimers, 1000);

            const terminateModal = document.getElementById("terminateRentalModal");
            if (terminateModal) {
                terminateModal.addEventListener("show.bs.modal", (event) => {
                    const button = event.relatedTarget;
                    if (!button) {
                        return;
                    }

                    const form = terminateModal.querySelector("[data-terminate-rental-form]");
                    const title = terminateModal.querySelector("[data-terminate-rental-title]");
                    const reference = terminateModal.querySelector("[data-terminate-rental-reference]");

                    if (form) {
                        form.action = button.dataset.rentalAction || "";
                    }

                    if (title) {
                        title.textContent = button.dataset.rentalTitle || "this rental";
                    }

                    if (reference) {
                        reference.textContent = button.dataset.rentalReference || "";
                    }
                });
            }
        })();
    </script>
}
