@model RentalReviewFormViewModel
@{
    Layout = "~/Views/Shared/Layouts/_AppLayout.cshtml";
    ViewData["Title"] = "Review Rental";
}

<div class="mb-4">
    <a class="btn btn-sm btn-outline-secondary" asp-controller="Rentals" asp-action="History">
        <i class="bi bi-arrow-left me-1" aria-hidden="true"></i> Rental history
    </a>
</div>

<section class="mb-4">
    <p class="text-uppercase text-muted small fw-semibold mb-1">Rental</p>
    <h1 class="h3 mb-1">Review GPU rental</h1>
    <p class="text-muted mb-0">Rate your completed rental experience.</p>
</section>

<div class="row g-4">
    <div class="col-12 col-lg-7">
        <form asp-action="Review" asp-route-rentalId="@Model.RentalId" method="post" class="profile-card">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

            <input type="hidden" asp-for="RentalId" />
            <input type="hidden" asp-for="GpuId" />

            <div class="d-flex gap-3 mb-4">
                @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" alt="@Model.GpuModel" class="rounded-3" style="width:128px;height:96px;object-fit:cover;" />
                }
                else
                {
                    <div class="rounded-3 d-flex align-items-center justify-content-center bg-body-secondary text-muted" style="width:128px;height:96px;">
                        <i class="bi bi-cpu fs-2" aria-hidden="true"></i>
                    </div>
                }
                <div class="min-width-0">
                    <h2 class="h5 mb-1">@Model.GpuModel</h2>
                    <div class="text-muted small">@Model.GpuName</div>
                    <div class="text-muted small">Owner: @Model.OwnerDisplayName</div>
                    <div class="text-muted small">@Model.ReferenceNumber</div>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Rating" class="form-label">Rating</label>
                <select asp-for="Rating" class="form-select">
                    <option value="5">5 stars</option>
                    <option value="4">4 stars</option>
                    <option value="3">3 stars</option>
                    <option value="2">2 stars</option>
                    <option value="1">1 star</option>
                </select>
                <span asp-validation-for="Rating" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Comment" class="form-label">Comment</label>
                <textarea asp-for="Comment" class="form-control" rows="5" maxlength="1000"></textarea>
                <div class="form-text">Optional, up to 1000 characters.</div>
                <span asp-validation-for="Comment" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-info">
                <i class="bi bi-send me-1" aria-hidden="true"></i> Submit review
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/Partials/_ValidationScriptsPartial.cshtml" />
}
