@using CloudCompute.Constants
@model RentalHistoryViewModel
@{
    Layout = "~/Views/Shared/Layouts/_AppLayout.cshtml";
    ViewData["Title"] = "Rental History";
    var statusMessage = TempData[GpuConstants.Status.TempDataMessageKey] as string;
    var statusType = TempData[GpuConstants.Status.TempDataTypeKey] as string;
    var alertClass = statusType == "danger" ? "alert-danger" : "alert-success";
    var reviewPromptRentalId = TempData[GpuConstants.Status.ReviewPromptRentalIdKey] as string;

    string StatusBadgeClass(RentalStatus status) => status switch
    {
        RentalStatus.Active => "text-bg-success",
        RentalStatus.Completed => "text-bg-success",
        RentalStatus.Terminated => "text-bg-warning",
        _ => "text-bg-light"
    };
}

<section class="mb-4">
    <p class="text-uppercase text-muted small fw-semibold mb-1">Platform</p>
    <h1 class="h3 mb-1">Rental History</h1>
    <p class="text-muted mb-0">Search and filter the GPU rentals tied to your account.</p>
</section>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @alertClass" role="alert">@statusMessage</div>
}

<form method="get" class="profile-card mb-4">
    <div class="row g-3">
        <div class="col-12 col-md-6 col-lg-4">
            <label class="form-label small text-muted" for="history-search">Search</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search" aria-hidden="true"></i></span>
                <input id="history-search" name="Search" class="form-control" value="@Model.Filter.Search"
                       placeholder="GPU model or reference #" />
            </div>
        </div>
        <div class="col-12 col-md-6 col-lg-3">
            <label class="form-label small text-muted" for="history-status">Status</label>
            <select id="history-status" name="Status" class="form-select">
                <option value="" selected="@(!Model.Filter.Status.HasValue)">All</option>
                <option value="@RentalStatus.Active" selected="@(Model.Filter.Status == RentalStatus.Active)">Active</option>
                <option value="@RentalStatus.Completed" selected="@(Model.Filter.Status == RentalStatus.Completed)">Completed</option>
                <option value="@RentalStatus.Terminated" selected="@(Model.Filter.Status == RentalStatus.Terminated)">Terminated</option>
            </select>
        </div>
        <div class="col-12 col-md-6 col-lg-3">
            <label class="form-label small text-muted" for="history-gpu-model">GPU model</label>
            <select id="history-gpu-model" name="GpuModel" class="form-select">
                <option value="" selected="@(string.IsNullOrWhiteSpace(Model.Filter.GpuModel))">Any model</option>
                @foreach (var modelName in Model.AvailableGpuModels)
                {
                    <option value="@modelName" selected="@(string.Equals(Model.Filter.GpuModel, modelName, StringComparison.OrdinalIgnoreCase))">@modelName</option>
                }
            </select>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <label class="form-label small text-muted" for="history-date-from">From</label>
            <input id="history-date-from" type="date" name="DateFrom" class="form-control"
                   value="@(Model.Filter.DateFrom?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <label class="form-label small text-muted" for="history-date-to">To</label>
            <input id="history-date-to" type="date" name="DateTo" class="form-control"
                   value="@(Model.Filter.DateTo?.ToString("yyyy-MM-dd"))" />
        </div>
    </div>
    <div class="d-flex flex-wrap gap-2 mt-3">
        <button type="submit" class="btn btn-info btn-sm">
            <i class="bi bi-funnel me-1" aria-hidden="true"></i> Apply
        </button>
        @if (Model.Filter.HasActiveFilters)
        {
            <a class="btn btn-outline-secondary btn-sm" asp-action="History">Clear filters</a>
        }
    </div>
</form>

@if (!Model.HasAnyRentals)
{
    <div class="profile-card text-center py-5">
        <i class="bi bi-lightning-charge fs-1 text-muted" aria-hidden="true"></i>
        <h2 class="h5 mt-3 mb-2">No rental history yet</h2>
        <p class="text-muted mb-3">Rent an available GPU to start building your history.</p>
        <a class="btn btn-info" asp-controller="Gpus" asp-action="Index">Browse GPUs</a>
    </div>
}
else if (Model.Items.Count == 0)
{
    <div class="profile-card text-center py-5">
        <i class="bi bi-funnel fs-1 text-muted" aria-hidden="true"></i>
        <h2 class="h5 mt-3 mb-2">No rentals match these filters</h2>
        <p class="text-muted mb-3">Adjust your search terms or clear the filters to see every rental.</p>
        <a class="btn btn-outline-secondary" asp-controller="Rentals" asp-action="History">Clear filters</a>
    </div>
}
else
{
    <section class="profile-card p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-sm mb-0 align-middle rental-history-table">
                <thead>
                    <tr>
                        <th class="ps-4">GPU</th>
                        <th>Rental window</th>
                        <th>Duration</th>
                        <th>Cost</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        var modalId = $"reviewModal-{item.Id:N}";
                        <tr>
                            <td class="ps-4">
                                <div class="fw-semibold">@item.GpuModel</div>
                                <div class="text-muted small">@item.ReferenceNumber</div>
                            </td>
                            <td>
                                @item.StartTime.ToLocalTime().ToString("MMM d, yyyy h:mm tt") -> @item.EndTime.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                            </td>
                            <td>@item.DurationHours h</td>
                            <td>@item.TotalCost.ToString("N2") credits</td>
                            <td>
                                <span class="badge rounded-pill @StatusBadgeClass(item.Status)">@item.Status</span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-inline-flex align-items-center justify-content-end gap-2">
                                    @{
                                        var isReviewable = item.Status == RentalStatus.Completed || item.Status == RentalStatus.Terminated;
                                    }
                                    @if (isReviewable && !item.HasReview)
                                    {
                                        <button type="button" class="btn btn-sm btn-info" data-bs-toggle="modal" data-bs-target="#@modalId">
                                            <i class="bi bi-star me-1" aria-hidden="true"></i> Review
                                        </button>
                                    }
                                    else if (isReviewable && item.HasReview)
                                    {
                                        <span class="badge rounded-pill text-bg-light border text-muted">Reviewed</span>
                                    }

                                    <a class="btn btn-sm btn-outline-info" asp-controller="Rentals" asp-action="Receipt" asp-route-rentalId="@item.Id"
                                       aria-label="View receipt" title="View receipt">
                                        <i class="bi bi-receipt" aria-hidden="true"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    @foreach (var item in Model.Items.Where(item => (item.Status == RentalStatus.Completed || item.Status == RentalStatus.Terminated) && !item.HasReview))
    {
        var modalId = $"reviewModal-{item.Id:N}";
        <div class="modal fade" id="@modalId" tabindex="-1" aria-labelledby="@(modalId)-title" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <form asp-controller="Rentals" asp-action="Review" asp-route-rentalId="@item.Id" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="RentalId" value="@item.Id" />

                        <div class="modal-header">
                            <div>
                                <h2 class="modal-title fs-5" id="@(modalId)-title">Review GPU rental</h2>
                                <div class="text-muted small">@item.ReferenceNumber</div>
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>

                        <div class="modal-body">
                            <div class="d-flex gap-3 mb-4">
                                @if (!string.IsNullOrWhiteSpace(item.ImagePath))
                                {
                                    <img src="@item.ImagePath" alt="@item.GpuModel" class="rounded-3 flex-shrink-0" style="width:112px;height:84px;object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="rounded-3 d-flex align-items-center justify-content-center bg-body-secondary text-muted flex-shrink-0" style="width:112px;height:84px;">
                                        <i class="bi bi-cpu fs-3" aria-hidden="true"></i>
                                    </div>
                                }
                                <div class="min-width-0">
                                    <div class="fw-semibold text-truncate">@item.GpuModel</div>
                                    <div class="text-muted small text-truncate">@item.GpuName</div>
                                    <div class="text-muted small text-truncate">Owner: @item.OwnerDisplayName</div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="form-label">Rating</div>
                                <div class="btn-group d-flex w-100" role="radiogroup" aria-label="Review rating">
                                    @for (var rating = 1; rating <= 5; rating++)
                                    {
                                        var ratingId = $"{modalId}-rating-{rating}";
                                        <input class="btn-check" type="radio" name="Rating" id="@ratingId" value="@rating" autocomplete="off" checked="@(rating == 5)" />
                                        <label class="btn btn-outline-warning flex-fill" for="@ratingId" aria-label="@rating star@(rating == 1 ? "" : "s")">
                                            <i class="bi bi-star-fill" aria-hidden="true"></i>
                                            <span class="visually-hidden">@rating star@(rating == 1 ? "" : "s")</span>
                                        </label>
                                    }
                                </div>
                            </div>

                            <div>
                                <label class="form-label" for="@(modalId)-comment">Comment</label>
                                <textarea class="form-control" id="@(modalId)-comment" name="Comment" rows="4" maxlength="1000"></textarea>
                                <div class="form-text">Optional, up to 1000 characters.</div>
                            </div>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-link" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-info">
                                <i class="bi bi-send me-1" aria-hidden="true"></i> Submit review
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}

@section Scripts {
    @if (!string.IsNullOrWhiteSpace(reviewPromptRentalId))
    {
        <script>
            (() => {
                const rentalId = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(reviewPromptRentalId));
                if (!rentalId) {
                    return;
                }
                const openReviewModal = () => {
                    const normalized = rentalId.replace(/-/g, "");
                    const modalEl = document.getElementById(`reviewModal-${normalized}`);
                    if (modalEl && window.bootstrap) {
                        bootstrap.Modal.getOrCreateInstance(modalEl).show();
                    }
                };
                if (document.readyState === "loading") {
                    document.addEventListener("DOMContentLoaded", openReviewModal);
                } else {
                    openReviewModal();
                }
            })();
        </script>
    }
}
