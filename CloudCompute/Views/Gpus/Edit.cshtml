@model GpuEditViewModel
@{
    Layout = "~/Views/Shared/Layouts/_AppLayout.cshtml";
    ViewData["Title"] = "Edit Listing";
}

<section class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Edit Listing</h1>
        <p class="text-muted mb-0">Update your hardware details, pricing, or photo.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Mine">
        <i class="bi bi-arrow-left me-1" aria-hidden="true"></i> Back to listings
    </a>
</section>

<partial name="~/Views/Shared/Partials/_ModelStateAlert.cshtml" />

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ExistingImagePath" />

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="profile-card mb-4">
                <h2 class="h6 mb-3">Hardware</h2>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Brand" class="form-label text-uppercase small text-muted">Brand</label>
                        <input asp-for="Brand" class="form-control" placeholder="e.g. NVIDIA" />
                        <span asp-validation-for="Brand" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Model" class="form-label text-uppercase small text-muted">Model</label>
                        <input asp-for="Model" class="form-control" placeholder="e.g. RTX 4090" />
                        <span asp-validation-for="Model" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="VramGb" class="form-label text-uppercase small text-muted">VRAM (GB)</label>
                        <input asp-for="VramGb" class="form-control" type="number" min="1" max="512" />
                        <span asp-validation-for="VramGb" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CudaCores" class="form-label text-uppercase small text-muted">CUDA / Stream Cores</label>
                        <input asp-for="CudaCores" class="form-control" type="number" min="1" max="200000" />
                        <span asp-validation-for="CudaCores" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="profile-card mb-4">
                <h2 class="h6 mb-3">Pricing &amp; Availability</h2>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="PricePerHour" class="form-label text-uppercase small text-muted">Price per hour (credits)</label>
                        <input asp-for="PricePerHour" class="form-control" type="number" step="0.01" min="1" max="100000" />
                        <span asp-validation-for="PricePerHour" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MinRentalHours" class="form-label text-uppercase small text-muted">Min rental duration (h)</label>
                        <input asp-for="MinRentalHours" class="form-control" type="number" min="1" max="168" />
                        <span asp-validation-for="MinRentalHours" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label text-uppercase small text-muted">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Cooling setup, network speed, special access..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="profile-card mb-4">
                <h2 class="h6 mb-3">Photo</h2>
                <div class="row g-3 align-items-stretch">
                    <div class="col-12 col-md-5">
                        <div class="text-muted small text-uppercase mb-2">Current photo</div>
                        @if (!string.IsNullOrWhiteSpace(Model.ExistingImagePath))
                        {
                            <img src="@Model.ExistingImagePath" alt="Current GPU photo" class="rounded-3 border w-100"
                                 style="height:180px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="rounded-3 border d-flex align-items-center justify-content-center bg-body-secondary text-muted"
                                 style="height:180px;">
                                <i class="bi bi-image fs-2" aria-hidden="true"></i>
                            </div>
                        }
                    </div>
                    <div class="col-12 col-md-7">
                        <div class="text-muted small text-uppercase mb-2">Replacement photo</div>
                        <label for="gpuPhotoInput" class="d-flex flex-column align-items-center justify-content-center text-center border border-1 rounded-3 p-4 h-100" style="cursor: pointer; min-height: 180px;">
                            <i class="bi bi-cloud-arrow-up fs-3 text-info" aria-hidden="true"></i>
                            <span class="fw-semibold mt-2">Choose new photo</span>
                            <span class="text-muted small">PNG, JPG, or WebP up to 5 MB</span>
                            <span class="text-muted small">Leave empty to keep the current photo.</span>
                        </label>
                    </div>
                </div>
                <input asp-for="Photo" id="gpuPhotoInput" type="file" class="d-none" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
                <div id="gpuPhotoFilename" class="text-muted small mt-2"></div>
                <span asp-validation-for="Photo" class="text-danger small"></span>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="profile-card position-lg-sticky" style="top: 1rem;">
                <p class="text-muted small mb-3">
                    Editing keeps your current approval status. Major changes may need a fresh admin review.
                </p>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-info">Save changes</button>
                    <a class="btn btn-outline-secondary" asp-action="Mine">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="~/Views/Shared/Partials/_ValidationScriptsPartial.cshtml" />
    <script>
        (() => {
            const input = document.getElementById("gpuPhotoInput");
            const label = document.getElementById("gpuPhotoFilename");
            if (!input || !label) return;
            input.addEventListener("change", () => {
                label.textContent = input.files && input.files[0] ? input.files[0].name : "";
            });
        })();
    </script>
}
