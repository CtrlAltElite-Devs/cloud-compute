@model GpuCatalogItemViewModel
@{
    var (statusLabel, statusClass) = Model.Status switch
    {
        GpuStatus.Available => ("Available", "text-bg-success"),
        GpuStatus.Rented => ("Rented", "text-bg-warning"),
        GpuStatus.Maintenance => ("Maintenance", "text-bg-secondary"),
        GpuStatus.Unavailable => ("Unavailable", "text-bg-secondary"),
        _ => (Model.Status.ToString(), "text-bg-light")
    };
}

<a class="gpu-card-link profile-card h-100 d-flex flex-column p-0 overflow-hidden" asp-controller="Gpus" asp-action="Detail" asp-route-id="@Model.Id" aria-label="View @Model.Model details">
    @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
    {
        <img src="@Model.ImagePath" alt="@Model.Model" loading="lazy" decoding="async" style="height:180px;object-fit:cover;" class="w-100" />
    }
    else
    {
        <div class="d-flex align-items-center justify-content-center bg-body-secondary text-muted" style="height:180px;">
            <i class="bi bi-cpu fs-1" aria-hidden="true"></i>
        </div>
    }

    <div class="p-3 d-flex flex-column gap-3 flex-grow-1">
        <div>
            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                @if (Model.IsOwnedByCurrentUser)
                {
                    <span class="badge text-bg-primary">Your listing</span>
                }
                <span class="badge @statusClass">@statusLabel</span>
                <span class="badge text-bg-secondary">@Model.Name</span>
            </div>
            <h2 class="h5 mb-1">@Model.Model</h2>
            <div class="text-muted small">by @Model.OwnerDisplayName</div>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <span class="badge text-bg-info">@Model.VramGb GB VRAM</span>
            <span class="badge text-bg-primary">@Model.CudaCores.ToString("N0") CUDA cores</span>
            <span class="badge text-bg-secondary">@Model.MinRentalHours hr min</span>
        </div>

        <div class="mt-auto">
            <div class="small mb-3">
                <i class="bi bi-star-fill text-warning" aria-hidden="true"></i>
                @if (Model.ReviewCount > 0 || Model.AverageRating > 0)
                {
                    <span>@Model.AverageRating.ToString("0.0") (@Model.ReviewCount)</span>
                }
                else
                {
                    <span class="text-muted">No reviews</span>
                }
            </div>

            <div>
                <div class="small text-muted">Per Hour</div>
                <div class="h5 mb-0">@Model.PricePerHour.ToString("N2")</div>
                <div class="small text-muted">credits/hr</div>
            </div>
        </div>
    </div>
</a>
