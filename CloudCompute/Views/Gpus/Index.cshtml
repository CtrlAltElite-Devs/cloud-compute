@model GpuCatalogViewModel
@{
    Layout = "~/Views/Shared/Layouts/_AppLayout.cshtml";
    ViewData["Title"] = "Browse GPUs";
}

<section class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div>
        <p class="text-uppercase text-muted small fw-semibold mb-1">Platform</p>
        <h1 class="h3 mb-1">Browse GPUs</h1>
        <p class="text-muted mb-0">Find approved GPUs available for immediate rental.</p>
    </div>
</section>

<form asp-action="Index" method="get" class="profile-card mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-12 col-lg">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search" aria-hidden="true"></i></span>
                <input id="search" name="search" class="form-control" value="@Model.Search"
                       placeholder="GPU name, model, or owner" />
            </div>
        </div>
        <div class="col-12 col-lg-auto d-flex gap-2">
            <button type="submit" class="btn btn-info">
                <i class="bi bi-search me-1" aria-hidden="true"></i> Search
            </button>
            @if (!string.IsNullOrWhiteSpace(Model.Search))
            {
                <a class="btn btn-outline-secondary" asp-action="Index">Clear</a>
            }
        </div>
    </div>
</form>

@if (Model.Items.Count == 0)
{
    <div class="profile-card text-center py-5">
        <i class="bi bi-cpu fs-1 text-muted" aria-hidden="true"></i>
        <h2 class="h5 mt-3 mb-2">No GPUs available</h2>
        <p class="text-muted mb-0">Try a different search or check back after owners publish more listings.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model.Items)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <partial name="Partials/_GpuCard" model="item" />
            </div>
        }
    </div>
}
