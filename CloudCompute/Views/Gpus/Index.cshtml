@model GpuCatalogViewModel
@{
    Layout = "~/Views/Shared/Layouts/_AppLayout.cshtml";
    ViewData["Title"] = "Browse GPUs";

    var sortOptions = new (GpuCatalogSort Value, string Label)[]
    {
        (GpuCatalogSort.Newest, "Newest"),
        (GpuCatalogSort.PriceAsc, "Price: low to high"),
        (GpuCatalogSort.PriceDesc, "Price: high to low"),
        (GpuCatalogSort.RatingDesc, "Highest rated")
    };

    string PageUrl(int page)
    {
        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(Url.Action("Index", "Gpus") ?? "/gpus", new Dictionary<string, string?>
        {
            ["Search"] = Model.Filter.Search,
            ["Sort"] = Model.Filter.Sort.ToString(),
            ["MinPrice"] = Model.Filter.MinPrice?.ToString(System.Globalization.CultureInfo.InvariantCulture),
            ["MaxPrice"] = Model.Filter.MaxPrice?.ToString(System.Globalization.CultureInfo.InvariantCulture),
            ["MinVramGb"] = Model.Filter.MinVramGb?.ToString(System.Globalization.CultureInfo.InvariantCulture),
            ["AvailableOnly"] = Model.Filter.AvailableOnly ? "true" : "false",
            ["PageSize"] = Model.Filter.PageSize.ToString(System.Globalization.CultureInfo.InvariantCulture),
            ["Page"] = page.ToString(System.Globalization.CultureInfo.InvariantCulture)
        });
    }

    var startIndex = Model.TotalCount == 0 ? 0 : ((Model.Page - 1) * Model.PageSize) + 1;
    var endIndex = Math.Min(Model.TotalCount, Model.Page * Model.PageSize);
}

<section class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div>
        <p class="text-uppercase text-muted small fw-semibold mb-1">Platform</p>
        <h1 class="h3 mb-1">Browse GPUs</h1>
        <p class="text-muted mb-0">Find approved GPUs available for immediate rental.</p>
    </div>
</section>

<form asp-action="Index" method="get" class="profile-card mb-4">
    <input type="hidden" name="Page" value="1" />
    <input type="hidden" name="PageSize" value="@Model.Filter.PageSize" />

    <div class="row g-3 align-items-end">
        <div class="col-12 col-lg">
            <label class="form-label small text-muted" for="catalog-search">Search</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search" aria-hidden="true"></i></span>
                <input id="catalog-search" name="Search" class="form-control" value="@Model.Filter.Search"
                       placeholder="GPU name, model, or owner" />
            </div>
        </div>
        <div class="col-12 col-lg-auto">
            <label class="form-label small text-muted" for="catalog-sort">Sort by</label>
            <select id="catalog-sort" name="Sort" class="form-select">
                @foreach (var option in sortOptions)
                {
                    <option value="@option.Value" selected="@(Model.Filter.Sort == option.Value)">@option.Label</option>
                }
            </select>
        </div>
    </div>

    <hr class="my-4" />

    <div class="row g-3">
        <div class="col-12 col-md-6 col-lg-4">
            <label class="form-label small text-muted" for="catalog-min-price">Min price (credits/hr)</label>
            <input type="number" min="0" step="0.01" id="catalog-min-price" name="MinPrice"
                   class="form-control" value="@(Model.Filter.MinPrice?.ToString("0.##"))" />
        </div>
        <div class="col-12 col-md-6 col-lg-4">
            <label class="form-label small text-muted" for="catalog-max-price">Max price (credits/hr)</label>
            <input type="number" min="0" step="0.01" id="catalog-max-price" name="MaxPrice"
                   class="form-control" value="@(Model.Filter.MaxPrice?.ToString("0.##"))" />
        </div>
        <div class="col-12 col-md-6 col-lg-4">
            <label class="form-label small text-muted" for="catalog-min-vram">Min VRAM (GB)</label>
            <input type="number" min="1" step="1" id="catalog-min-vram" name="MinVramGb"
                   class="form-control" value="@Model.Filter.MinVramGb" />
        </div>
        <div class="col-12 col-md-6 col-lg-4 d-flex align-items-end">
            <div class="form-check">
                <input type="hidden" name="AvailableOnly" value="false" />
                <input class="form-check-input" type="checkbox" id="catalog-available-only" name="AvailableOnly" value="true"
                       checked="@Model.Filter.AvailableOnly" />
                <label class="form-check-label" for="catalog-available-only">
                    Only show available GPUs
                </label>
            </div>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 mt-4">
        <button type="submit" class="btn btn-info">
            <i class="bi bi-funnel me-1" aria-hidden="true"></i> Apply
        </button>
        @if (Model.Filter.HasActiveFilters)
        {
            <a class="btn btn-outline-secondary" asp-action="Index">Clear filters</a>
        }
    </div>
</form>

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div class="text-muted small">
        @if (Model.TotalCount == 0)
        {
            <span>No GPUs match your filters.</span>
        }
        else
        {
            <span>Showing @startIndex–@endIndex of @Model.TotalCount</span>
        }
    </div>
</div>

@if (Model.Items.Count == 0)
{
    <div class="profile-card text-center py-5">
        <i class="bi bi-cpu fs-1 text-muted" aria-hidden="true"></i>
        <h2 class="h5 mt-3 mb-2">No GPUs available</h2>
        <p class="text-muted mb-0">Try a different search or check back after owners publish more listings.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model.Items)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <partial name="Partials/_GpuCard" model="item" />
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4" aria-label="GPU catalog pages">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    @if (Model.HasPreviousPage)
                    {
                        <a class="page-link" href="@PageUrl(Model.Page - 1)">Previous</a>
                    }
                    else
                    {
                        <span class="page-link">Previous</span>
                    }
                </li>
                @{
                    var windowStart = Math.Max(1, Model.Page - 2);
                    var windowEnd = Math.Min(Model.TotalPages, Model.Page + 2);
                }
                @if (windowStart > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@PageUrl(1)">1</a>
                    </li>
                    @if (windowStart > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                }
                @for (var p = windowStart; p <= windowEnd; p++)
                {
                    var pageNum = p;
                    <li class="page-item @(pageNum == Model.Page ? "active" : "")">
                        @if (pageNum == Model.Page)
                        {
                            <span class="page-link">@pageNum</span>
                        }
                        else
                        {
                            <a class="page-link" href="@PageUrl(pageNum)">@pageNum</a>
                        }
                    </li>
                }
                @if (windowEnd < Model.TotalPages)
                {
                    @if (windowEnd < Model.TotalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link" href="@PageUrl(Model.TotalPages)">@Model.TotalPages</a>
                    </li>
                }
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    @if (Model.HasNextPage)
                    {
                        <a class="page-link" href="@PageUrl(Model.Page + 1)">Next</a>
                    }
                    else
                    {
                        <span class="page-link">Next</span>
                    }
                </li>
            </ul>
        </nav>
    }
}
