@{
    Layout = "~/Views/Shared/Layouts/_AppLayout.cshtml";
    ViewData["Title"] = "List a GPU";
}

<section class="mb-4">
    <p class="text-uppercase text-muted small fw-semibold mb-1">Owner</p>
    <h1 class="h3 mb-1">List a GPU</h1>
    <p class="text-muted mb-0">Coming soon.</p>
</section>

<div class="border rounded-3 p-4">
    <p class="mb-0">
        Submit a new GPU listing with model, VRAM, CUDA cores, and your hourly credit price.
