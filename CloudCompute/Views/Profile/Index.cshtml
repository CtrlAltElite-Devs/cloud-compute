@model ProfilePageViewModel
@{
    Layout = "~/Views/Shared/Layouts/_AppLayout.cshtml";
    ViewData["Title"] = "Profile";

    var statusMessage = TempData["ProfileStatusMessage"] as string;
    var statusType = TempData["ProfileStatusType"] as string;
    var alertClass = statusType == "danger" ? "alert-danger" : "alert-success";

    var displayName = Model.FullName;
    if (string.IsNullOrWhiteSpace(displayName))
    {
        displayName = Model.UserName;
    }

    var initials = ComputeInitials(displayName);
    var hasAvatar = !string.IsNullOrWhiteSpace(Model.ProfilePicturePath);
}
@functions {
    private static string ComputeInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..1].ToUpperInvariant();
        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }
}

<section class="mb-4">
    <h1 class="h3 mb-1">Profile</h1>
    <p class="text-muted mb-0">Manage your identity and credentials.</p>
</section>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @alertClass" role="alert">@statusMessage</div>
}

<div class="profile-card mb-4">
    <div class="d-flex align-items-center gap-3">
        @if (hasAvatar)
        {
            <img class="profile-avatar-image" src="@Model.ProfilePicturePath" alt="Profile picture for @displayName" />
        }
        else
        {
            <div class="profile-avatar-image profile-avatar-initials" aria-hidden="true">@initials</div>
        }

        <div class="flex-grow-1 min-width-0">
            <h2 class="h5 mb-1">@displayName</h2>
            <p class="text-muted mb-2">@@@Model.UserName</p>

            <div class="d-flex flex-wrap align-items-center gap-2">
                <form asp-action="UploadAvatar" asp-controller="Profile" method="post" enctype="multipart/form-data" class="mb-0">
                    <input type="file"
                           name="avatar"
                           id="avatarInput"
                           accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
                           class="d-none"
                           onchange="this.form.submit()" />
                    <label for="avatarInput" class="btn btn-outline-secondary btn-sm mb-0">
                        Upload New
                    </label>
                </form>
                @if (hasAvatar)
                {
                    <form asp-action="RemoveAvatar" asp-controller="Profile" method="post" class="mb-0">
                        <button type="submit" class="btn btn-outline-danger btn-sm">Remove</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

<div class="profile-card mb-4">
    <h2 class="h5 mb-3">Personal Information</h2>
    <partial name="Partials/_ProfileForm" model="Model.Profile" />
</div>

<div class="profile-card mb-4">
    <h2 class="h5 mb-3">Change Password</h2>
    <partial name="Partials/_PasswordForm" model="Model.Password" />
</div>

<div class="profile-card border-danger-subtle">
    <h2 class="h5 mb-2 text-danger">Delete Account</h2>
    <p class="text-muted mb-3">
        Permanently deactivates your account and removes your personal information. Your rental and credit
        history is preserved for accounting purposes. This action cannot be undone.
    </p>
    <button class="btn btn-outline-danger" type="button" data-bs-toggle="modal" data-bs-target="#deleteAccountModal">
        Delete Account
    </button>
</div>

<div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-labelledby="deleteAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="DeleteAccount" asp-controller="Profile" method="post">
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="deleteAccountModalLabel">Delete your account?</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-3">
                        This will deactivate your account, anonymize your personal information, and pause any active
                        listings you own. Your rental and credit history will be retained. You will be signed out
                        immediately and will not be able to sign back in.
                    </p>
                    <div class="mb-2">
                        <label class="form-label" for="DeleteAccount_CurrentPassword">Confirm with your current password</label>
                        <input class="form-control" type="password" id="DeleteAccount_CurrentPassword"
                               name="CurrentPassword" autocomplete="current-password" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-danger" type="submit">Delete Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/Partials/_ValidationScriptsPartial.cshtml" />
    <script>
        (() => {
            const form = document.getElementById("profileForm");
            if (!form) return;
            const submitButton = form.querySelector("button[type='submit']");
            if (!submitButton) return;

            const fields = Array.from(form.querySelectorAll("input:not([type='hidden']), textarea"));
            const initialValues = fields.map(field => field.value);

            const updateDirtyState = () => {
                const isDirty = fields.some((field, index) => field.value !== initialValues[index]);
                submitButton.disabled = !isDirty;
            };

            fields.forEach(field => {
                field.addEventListener("input", updateDirtyState);
                field.addEventListener("change", updateDirtyState);
            });

            updateDirtyState();
        })();
    </script>
}
