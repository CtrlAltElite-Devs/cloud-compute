@using CloudCompute.Models.Enums
@{
    var isAdmin = User.IsInRole(nameof(UserRole.Admin));
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CloudCompute</title>

    <script>
        (() => {
            const storedTheme = localStorage.getItem("theme");
            const getPreferredTheme = () => {
                if (storedTheme === "light" || storedTheme === "dark") {
                    return storedTheme;
                }
                return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
            };

            document.documentElement.setAttribute("data-bs-theme", getPreferredTheme());
        })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>

<body class="app-body @ViewData["BodyClass"]">
    <header class="app-mobile-topbar d-md-none">
        <button class="app-mobile-topbar-toggle" type="button" data-bs-toggle="offcanvas" data-bs-target="#appSidebar" aria-controls="appSidebar" aria-label="Open navigation">
            <i class="bi bi-list" aria-hidden="true"></i>
        </button>
        @if (isAdmin)
        {
            <a class="app-mobile-topbar-brand" asp-controller="Admin" asp-action="Dashboard">
                <img class="brand-logo" src="~/images/logo.png" alt="" aria-hidden="true" asp-append-version="true" />
                <span>CloudCompute</span>
            </a>
        }
        else
        {
            <a class="app-mobile-topbar-brand" asp-controller="Dashboard" asp-action="Index">
                <img class="brand-logo" src="~/images/logo.png" alt="" aria-hidden="true" asp-append-version="true" />
                <span>CloudCompute</span>
            </a>
        }
    </header>

    <div class="app-shell">
        <partial name="~/Views/Shared/Partials/_Sidebar.cshtml" />

        <main class="app-main" role="main">
            <partial name="~/Views/Shared/Partials/_AppHeader.cshtml" />
            <div class="app-main-inner">
                @RenderBody()
            </div>
        </main>
    </div>

    <partial name="~/Views/Shared/Partials/_LogoutModal.cshtml" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
