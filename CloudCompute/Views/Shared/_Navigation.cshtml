<header class="sticky-top py-2 px-1">
    <nav class="navbar">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <div>
                <a class="navbar-brand playfair fs-4 fw-bolder" asp-area="" asp-controller="Landing" asp-action="Index">CloudCompute</a>
            </div>
            <div class="d-flex justify-content-end align-items-center gap-2">
                <div class="dropdown">
                    <button class="btn btn-sm dropdown-toggle border-0 shadow-none theme-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" id="themeMenuButton" aria-label="Select color theme">
                        <i class="bi bi-circle-half" aria-hidden="true" id="themeMenuIcon"></i>
                        <span class="visually-hidden" id="themeMenuText">Auto</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="themeMenuButton">
                        <li>
                            <button class="dropdown-item" type="button" data-theme-value="light">
                                <i class="bi bi-sun-fill me-2" aria-hidden="true"></i>Light
                            </button>
                        </li>
                        <li>
                            <button class="dropdown-item" type="button" data-theme-value="dark">
                                <i class="bi bi-moon-stars-fill me-2" aria-hidden="true"></i>Dark
                            </button>
                        </li>
                        <li>
                            <button class="dropdown-item" type="button" data-theme-value="auto">
                                <i class="bi bi-circle-half me-2" aria-hidden="true"></i>Auto
                            </button>
                        </li>
                    </ul>
                </div>
                <div class="d-flex align-items-center">
                    <a class="btn btn-primary btn-sm px-3" href="#">
                        Login
                    </a>
                </div>
            </div>
        </div>
    </nav>
</header>
