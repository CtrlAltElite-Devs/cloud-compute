@model CreditBalanceViewModel
<a class="app-header-credit" asp-controller="Dashboard" asp-action="Index" aria-label="Credit balance: @Model.Display credits">
    <i class="bi bi-coin" aria-hidden="true"></i>
    <span class="app-header-credit-value">@Model.Display</span>
    <span class="app-header-credit-label">credits</span>
</a>
